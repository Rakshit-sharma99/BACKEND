# Social Claw service environment variables

# Server
PORT=7110

# JWT (same secret as other services)
ACCESS_TOKEN_SECRET=your_jwt_secret_here

# Kafka
KAFKA_BROKER=kafka:9092

# WhatsApp bridge settings
MESSAGE_RETENTION_DAYS=7
CONTEXT_FILE_MAX_KB=50

# Idle session cleanup (ms) — disconnect Baileys sessions inactive for this long
IDLE_TIMEOUT_MS=1800000
