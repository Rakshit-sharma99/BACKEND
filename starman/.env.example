# Starman service environment variables

# Server
PORT=5100

# JWT (same secret as other services)
ACCESS_TOKEN_SECRET=your_jwt_secret_here

# Gemini API
GEMINI_API_KEY=your_gemini_api_key_here

# Microservice URLs (Docker internal hostnames)
MAP_URL=http://map:5090/map/api/v1
EVENT_URL=http://event:5060/event/api/v1
UNIVERSE_URL=http://universe:5050/universe/api/v1
MULTIVERSE_URL=http://multiverse:5070/multiverse/api/v1
IPLS_URL=http://ipls:5080/ipls/api/v1
TICKET_URL=http://ticket:6000/ticket/api/v1

# MongoDB
MONGO_URI=mongodb://mongo:27017/starman

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# Microservice URLs
CONTENT_URL=http://content:5000/content/api/v1
KNOWLEDGE_URL=http://knowledge:7080/knowledge/api/v1
TICKET_URL=http://ticket:6000/ticket/api/v1

# Kafka
KAFKA_BROKER=kafka:9092

# Signal Relay — Starman bot user ObjectId (create a dedicated user in MongoDB)
# Leave empty to disable autonomous posting
STARMAN_BOT_USER_ID=
