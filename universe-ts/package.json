{
  "name": "macbease-backend-typescript",
  "version": "1.0.0",
  "description": "MacBease App Backend in TypeScript",
  "main": "dist/src/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "swc src -d dist --copy-files",
    "start": "swc src -d dist --copy-files && node dist/src/server.js",
    "test": "jest --runInBand",
    "format": "prettier --write \"src/**/*.{js,ts,json,md}\"",
    "lint": "eslint src --ext .ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Macbease/macbease-backend-typescript.git"
  },
  "keywords": [],
  "author": "Amartya Ayush",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Macbease/macbease-backend-typescript/issues"
  },
  "homepage": "https://github.com/Macbease/macbease-backend-typescript#readme",
  "dependencies": {
    "@aws-sdk/client-secrets-manager": "^3.738.0",
    "@swc/jest": "^0.2.37",
    "@types/supertest": "^6.0.2",
    "aws-sdk": "^2.1692.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.5",
    "compromise": "^14.14.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "firebase-admin": "^13.0.2",
    "google-auth-library": "^9.15.1",
    "helmet": "^8.0.0",
    "http": "^0.0.1-security",
    "http-status-codes": "^2.3.0",
    "ioredis": "^5.5.0",
    "jest": "^29.7.0",
    "jsonwebtoken": "^9.0.2",
    "mailgen": "^2.0.29",
    "moment-timezone": "^0.5.47",
    "mongoose": "^8.9.5",
    "node-schedule": "^2.1.1",
    "nodemailer": "^6.10.0",
    "openai": "^4.81.0",
    "path": "^0.12.7",
    "pdfkit": "^0.16.0",
    "prettier": "^3.5.2",
    "razorpay": "^2.9.5",
    "socket.io": "^4.8.1",
    "supertest": "^7.0.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.3",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@swc/cli": "^0.6.0",
    "@swc/core": "^1.10.12",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/node-schedule": "^2.1.7",
    "@types/pdfkit": "^0.13.9",
    "@typescript-eslint/eslint-plugin": "^8.26.0",
    "@typescript-eslint/parser": "^8.26.0",
    "eslint": "^9.22.0",
    "globals": "^16.0.0",
    "typescript-eslint": "^8.26.0"
  }
}
